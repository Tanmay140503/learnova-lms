@model List<Learnova.Models.Entities.Course>
@{
    ViewData["Title"] = "Courses Dashboard";
    var viewType = ViewBag.View as string ?? "kanban";
    var searchQuery = ViewBag.Search as string ?? "";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="fas fa-layer-group text-primary me-2"></i>Courses Dashboard
            </h2>
            <p class="text-muted mb-0">Manage your courses, lessons, and quizzes</p>
        </div>
        <button class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#createCourseModal">
            <i class="fas fa-plus me-2"></i> Create Course
        </button>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">Total Courses</h6>
                            <h2 class="mb-0">@Model.Count</h2>
                        </div>
                        <i class="fas fa-book fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">Published</h6>
                            <h2 class="mb-0">@Model.Count(c => c.IsPublished)</h2>
                        </div>
                        <i class="fas fa-globe fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="opacity-75 mb-1">Drafts</h6>
                            <h2 class="mb-0">@Model.Count(c => !c.IsPublished)</h2>
                        </div>
                        <i class="fas fa-edit fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">Total Lessons</h6>
                            <h2 class="mb-0">@Model.Sum(c => c.TotalLessons)</h2>
                        </div>
                        <i class="fas fa-play-circle fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and View Toggle -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <form asp-action="Dashboard" method="get" class="d-flex">
                        <div class="input-group">
                            <span class="input-group-text bg-white">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                            <input type="text" name="search" class="form-control border-start-0"
                                   placeholder="Search courses by title or tags..." value="@searchQuery" />
                            <input type="hidden" name="view" value="@viewType" />
                            <button class="btn btn-primary" type="submit">Search</button>
                        </div>
                    </form>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <div class="btn-group" role="group">
                        <a asp-action="Dashboard" asp-route-view="kanban" asp-route-search="@searchQuery"
                           class="btn @(viewType == "kanban" ? "btn-primary" : "btn-outline-primary")">
                            <i class="fas fa-th-large me-1"></i> Kanban
                        </a>
                        <a asp-action="Dashboard" asp-route-view="list" asp-route-search="@searchQuery"
                           class="btn @(viewType == "list" ? "btn-primary" : "btn-outline-primary")">
                            <i class="fas fa-list me-1"></i> List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <!-- Empty State -->
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="fas fa-book-open fa-5x text-muted mb-4"></i>
                <h4>No Courses Found</h4>
                <p class="text-muted mb-4">
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <span>No courses match your search "<strong>@searchQuery</strong>"</span>
                    }
                    else
                    {
                        <span>You haven't created any courses yet. Let's create your first course!</span>
                    }
                </p>
                <button class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#createCourseModal">
                    <i class="fas fa-plus me-2"></i> Create Your First Course
                </button>
            </div>
        </div>
    }
    else if (viewType == "kanban")
    {
        <!-- Kanban View -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var course in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm course-card">
                        <!-- Course Image -->
                        <div class="position-relative overflow-hidden">
                            @if (!string.IsNullOrEmpty(course.CourseImageUrl))
                            {
                                <img src="@course.CourseImageUrl" class="card-img-top" alt="@course.Title"
                                     style="height: 180px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="card-img-top bg-gradient d-flex align-items-center justify-content-center"
                                     style="height: 180px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                    <i class="fas fa-book fa-4x text-white opacity-75"></i>
                                </div>
                            }
                            <!-- Status Badge -->
                            <div class="position-absolute top-0 end-0 m-2">
                                @if (course.IsPublished)
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-globe me-1"></i> Published
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="fas fa-edit me-1"></i> Draft
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="card-body">
                            <h5 class="card-title mb-2">@course.Title</h5>

                            @if (!string.IsNullOrEmpty(course.Tags))
                            {
                                <div class="mb-2">
                                    @foreach (var tag in course.Tags.Split(',').Take(3))
                                    {
                                        <span class="badge bg-light text-dark border me-1">@tag.Trim()</span>
                                    }
                                </div>
                            }

                            <div class="row text-center text-muted small mt-3">
                                <div class="col-4">
                                    <i class="fas fa-eye d-block mb-1"></i>
                                    <span>@course.ViewsCount</span>
                                </div>
                                <div class="col-4">
                                    <i class="fas fa-book-open d-block mb-1"></i>
                                    <span>@course.TotalLessons</span>
                                </div>
                                <div class="col-4">
                                    <i class="fas fa-clock d-block mb-1"></i>
                                    <span>@course.TotalDurationMinutes m</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0">
                            <div class="d-flex gap-2">
                                <a asp-action="EditCourse" asp-route-id="@course.Id"
                                   class="btn btn-primary btn-sm flex-grow-1">
                                    <i class="fas fa-edit me-1"></i> Edit
                                </a>
                                <button class="btn btn-outline-secondary btn-sm"
                                        onclick="shareCourse(@course.Id)" title="Share">
                                    <i class="fas fa-share-alt"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm"
                                        onclick="deleteCourse(@course.Id)" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- List View -->
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;"></th>
                            <th>Course Title</th>
                            <th>Tags</th>
                            <th class="text-center">Views</th>
                            <th class="text-center">Lessons</th>
                            <th class="text-center">Duration</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(course.CourseImageUrl))
                                    {
                                        <img src="@course.CourseImageUrl" alt="@course.Title"
                                             class="rounded" style="width: 45px; height: 45px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded d-flex align-items-center justify-content-center"
                                             style="width: 45px; height: 45px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                            <i class="fas fa-book text-white"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <strong>@course.Title</strong>
                                    @if (!string.IsNullOrEmpty(course.ShortDescription))
                                    {
                                        <br />
                            
                                        <small class="text-muted">@(course.ShortDescription.Length > 50 ? course.ShortDescription.Substring(0, 50) + "..." : course.ShortDescription)</small>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(course.Tags))
                                    {
                                        @foreach (var tag in course.Tags.Split(',').Take(2))
                                        {
                                            <span class="badge bg-secondary me-1">@tag.Trim()</span>
                                        }
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark">
                                        <i class="fas fa-eye me-1"></i> @course.ViewsCount
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary">@course.TotalLessons</span>
                                </td>
                                <td class="text-center">
                                    <span class="text-muted">@course.TotalDurationMinutes mins</span>
                                </td>
                                <td class="text-center">
                                    @if (course.IsPublished)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle me-1"></i> Published
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fas fa-edit me-1"></i> Draft
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a asp-action="EditCourse" asp-route-id="@course.Id"
                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                onclick="shareCourse(@course.Id)" title="Share">
                                            <i class="fas fa-share-alt"></i>
                                        </button>
                                        <a href="@Url.Action("CourseDetail", "Learner", new { id = course.Id })"
                                           target="_blank" class="btn btn-sm btn-outline-info" title="Preview">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger"
                                                onclick="deleteCourse(@course.Id)" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Create Course Modal -->
<div class="modal fade" id="createCourseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-plus-circle me-2"></i> Create New Course
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="createCourseForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-bold">Course Title <span class="text-danger">*</span></label>
                        <input type="text" id="newCourseTitle" class="form-control form-control-lg"
                               placeholder="Enter course title" autofocus />
                        <div class="form-text">Give your course a clear, descriptive title</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" id="btnCreateCourse">
                    <i class="fas fa-plus me-1"></i> Create Course
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p class="mb-0">Are you sure you want to delete this course?</p>
                <p class="text-muted mb-0 mt-2">
                    <i class="fas fa-info-circle me-1"></i>
                    This will also delete all lessons, quizzes, and enrollments.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fas fa-trash me-1"></i> Delete Course
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>

@section Scripts {
    <script>
        // CSRF Token
        var csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
        var courseToDelete = null;

        // ========== CREATE COURSE ==========
        document.getElementById('btnCreateCourse').addEventListener('click', function() {
            createCourse();
        });

        document.getElementById('newCourseTitle').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                createCourse();
            }
        });

        function createCourse() {
            var title = document.getElementById('newCourseTitle').value.trim();
            if (!title) {
                document.getElementById('newCourseTitle').classList.add('is-invalid');
                alert('Please enter a course title');
                return;
            }

            document.getElementById('newCourseTitle').classList.remove('is-invalid');

            var btn = document.getElementById('btnCreateCourse');
            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Creating...';
            btn.disabled = true;

            fetch('@Url.Action("QuickCreateCourse", "Instructor")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': csrfToken
                },
                body: 'title=' + encodeURIComponent(title) + '&__RequestVerificationToken=' + encodeURIComponent(csrfToken)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.href = '@Url.Action("EditCourse", "Instructor")/' + data.courseId;
                } else {
                    alert(data.message || 'Failed to create course');
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
                btn.innerHTML = originalText;
                btn.disabled = false;
            });
        }

        // Clear modal on close
        document.getElementById('createCourseModal').addEventListener('hidden.bs.modal', function() {
            document.getElementById('newCourseTitle').value = '';
            document.getElementById('newCourseTitle').classList.remove('is-invalid');
        });

        // ========== SHARE COURSE ==========
        function shareCourse(courseId) {
            var url = window.location.origin + '/Learner/CourseDetail/' + courseId;

            if (navigator.clipboard) {
                navigator.clipboard.writeText(url).then(function() {
                    showToast('Course link copied to clipboard!', 'success');
                }).catch(function() {
                    fallbackCopyToClipboard(url);
                });
            } else {
                fallbackCopyToClipboard(url);
            }
        }

        function fallbackCopyToClipboard(text) {
            var textArea = document.createElement('textarea');
            textArea.value = text;
            textArea.style.position = 'fixed';
            textArea.style.left = '-9999px';
            document.body.appendChild(textArea);
            textArea.select();
            try {
                document.execCommand('copy');
                showToast('Course link copied to clipboard!', 'success');
            } catch (err) {
                showToast('Failed to copy link', 'danger');
            }
            document.body.removeChild(textArea);
        }

        // ========== DELETE COURSE ==========
        function deleteCourse(courseId) {
            courseToDelete = courseId;
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            deleteModal.show();
        }

        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            if (!courseToDelete) return;

            var btn = this;
            var originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Deleting...';
            btn.disabled = true;

            fetch('@Url.Action("DeleteCourse", "Instructor")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': csrfToken
                },
                body: 'id=' + courseToDelete + '&__RequestVerificationToken=' + encodeURIComponent(csrfToken)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                    showToast('Course deleted successfully!', 'success');
                    setTimeout(function() {
                        location.reload();
                    }, 1000);
                } else {
                    alert(data.message || 'Failed to delete course');
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
                btn.innerHTML = originalText;
                btn.disabled = false;
            });
        });

        // ========== TOAST NOTIFICATION ==========
        function showToast(message, type) {
            var toastHtml =
                '<div class="toast align-items-center text-white bg-' + type + ' border-0" role="alert">' +
                    '<div class="d-flex">' +
                        '<div class="toast-body">' + message + '</div>' +
                        '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                    '</div>' +
                '</div>';

            var toastContainer = document.getElementById('toastContainer');
            toastContainer.insertAdjacentHTML('beforeend', toastHtml);

            var toastEl = toastContainer.querySelector('.toast:last-child');
            var toast = new bootstrap.Toast(toastEl, { delay: 3000 });
            toast.show();

            toastEl.addEventListener('hidden.bs.toast', function() {
                toastEl.remove();
            });
        }
    </script>
}

<style>
    .course-card {
        transition: all 0.3s ease;
        border: none;
    }

        .course-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
        }

        .course-card .card-img-top {
            transition: transform 0.3s ease;
        }

        .course-card:hover .card-img-top {
            transform: scale(1.05);
        }

    .bg-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .is-invalid {
        border-color: #dc3545;
    }
</style>
