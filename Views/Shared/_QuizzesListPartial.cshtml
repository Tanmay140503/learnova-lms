@model List<Learnova.Models.Entities.Quiz>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info mb-0">
        <div class="d-flex align-items-center">
            <i class="fas fa-info-circle fa-2x me-3"></i>
            <div>
                <strong>No quizzes added yet</strong>
                <p class="mb-0">Click "Create Quiz" to add your first quiz</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var quiz in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="card-title mb-1">
                                    <i class="fas fa-question-circle text-primary me-2"></i>
                                    @quiz.Title
                                </h5>
                                @if (!string.IsNullOrEmpty(quiz.Description))
                                {
                                    <p class="text-muted small mb-0">@quiz.Description</p>
                                }
                            </div>
                            <span class="badge bg-primary rounded-pill">
                                @quiz.Questions?.Count questions
                            </span>
                        </div>

                        <!-- Points Info -->
                        <div class="row text-center mb-3">
                            <div class="col-3">
                                <div class="small text-muted">1st Try</div>
                                <strong class="text-success">@quiz.FirstAttemptPoints pts</strong>
                            </div>
                            <div class="col-3">
                                <div class="small text-muted">2nd Try</div>
                                <strong class="text-info">@quiz.SecondAttemptPoints pts</strong>
                            </div>
                            <div class="col-3">
                                <div class="small text-muted">3rd Try</div>
                                <strong class="text-warning">@quiz.ThirdAttemptPoints pts</strong>
                            </div>
                            <div class="col-3">
                                <div class="small text-muted">4th+</div>
                                <strong class="text-secondary">@quiz.FourthAttemptPoints pts</strong>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0">
                        <div class="d-flex gap-2">
                            <a asp-controller="Instructor" asp-action="QuizBuilder"
                               asp-route-id="@quiz.Id" asp-route-courseId="@quiz.CourseId"
                               class="btn btn-outline-primary flex-grow-1">
                                <i class="fas fa-edit me-1"></i> Edit Quiz
                            </a>
                            <button class="btn btn-outline-danger" onclick="deleteQuiz(@quiz.Id)" title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}