@model List<CourseEnrollment>
@using Learnova.Models.Entities
@{
    ViewData["Title"] = "My Learning";
    var user = ViewBag.User as ApplicationUser;
    var badge = ViewBag.Badge as string ?? "Beginner";
    var nextPoints = ViewBag.NextBadgePoints != null ? (int)ViewBag.NextBadgePoints : 20;
    var userPoints = user?.TotalPoints ?? 0;
    var progressToNext = nextPoints > 0 ? Math.Min(100, (userPoints * 100) / nextPoints) : 0;
}

<div class="container py-4">
    <div class="row g-4">
        <!-- Profile Panel -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-user-circle fa-4x text-primary"></i>
                    </div>
                    <h5 class="fw-bold">@user?.FirstName @user?.LastName</h5>
                    <p class="text-muted mb-3">@user?.Email</p>

                    <div class="bg-light rounded p-3 mb-3">
                        <h6 class="fw-bold mb-1">Total Points</h6>
                        <h3 class="text-warning mb-2"><i class="fas fa-star"></i> @userPoints</h3>
                        <span class="badge bg-primary fs-6">@badge</span>
                    </div>

                    <div class="text-start">
                        <small class="text-muted">Progress to @(badge == "Master" ? "Max Level" : "Next Rank")</small>
                        <div class="progress mt-1" style="height: 8px;">
                            <div class="progress-bar bg-warning" style="width: @progressToNext%"></div>
                        </div>
                        <small class="text-muted">@userPoints / @nextPoints pts</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Courses Grid -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold">My Courses</h2>
                <form method="get" class="d-flex gap-2">
                    <input type="text" name="search" class="form-control" placeholder="Search courses..." value="@ViewBag.Search" />
                    <button class="btn btn-primary"><i class="fas fa-search"></i></button>
                </form>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-book-open fa-3x mb-3"></i>
                    <p>No courses enrolled yet. <a asp-action="Courses">Browse courses</a></p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var enrollment in Model)
                    {
                        var course = enrollment.Course;
                        if (course == null) continue;

                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 shadow-sm border-0">
                                <img src="@(course.CourseImageUrl ?? "/img/placeholder.jpg")" class="card-img-top" style="height:160px;object-fit:cover;" alt="@course.Title" />
                                <div class="card-body d-flex flex-column">
                                    <h5 class="fw-bold">@course.Title</h5>
                                    <p class="text-muted small flex-grow-1">
                                        @if (!string.IsNullOrEmpty(course.ShortDescription))
                                        {
                                            @(course.ShortDescription.Length > 80 ? course.ShortDescription.Substring(0, 80) + "..." : course.ShortDescription)
                                        }
                                    </p>
                                    <div class="mb-2">
                                        @if (!string.IsNullOrEmpty(course.Tags))
                                        {
                                            foreach (var tag in course.Tags.Split(',').Take(2))
                                            {
                                                <span class="badge bg-light text-dark me-1">@tag.Trim()</span>
                                            }
                                        }
                                    </div>
                                    <div class="mb-2">
                                        <small class="text-muted">Progress: @enrollment.CompletionPercentage%</small>
                                    </div>
                                    <div class="progress mb-3" style="height:6px;">
                                        <div class="progress-bar bg-success" style="width:@enrollment.CompletionPercentage%"></div>
                                    </div>

                                    @if (enrollment.Status == "Completed")
                                    {
                                        <a asp-action="CourseDetail" asp-route-id="@course.Id" class="btn btn-outline-success w-100">
                                            <i class="fas fa-check-circle me-1"></i> Review
                                        </a>
                                    }
                                    else if (enrollment.CompletionPercentage > 0)
                                    {
                                        <a asp-action="CourseDetail" asp-route-id="@course.Id" class="btn btn-primary w-100">
                                            <i class="fas fa-play me-1"></i> Continue
                                        </a>
                                    }
                                    else if (course.AccessRule == "OnPayment" && course.Price > 0)
                                    {
                                        <button class="btn btn-warning w-100" onclick="alert('Payment gateway integration pending')">
                                            <i class="fas fa-shopping-cart me-1"></i> Buy ($@course.Price)
                                        </button>
                                    }
                                    else
                                    {
                                        <a asp-action="CourseDetail" asp-route-id="@course.Id" class="btn btn-success w-100">
                                            <i class="fas fa-rocket me-1"></i> Start
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
