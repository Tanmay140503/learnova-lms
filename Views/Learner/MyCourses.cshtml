@model List<Learnova.Models.Entities.CourseEnrollment>
@{
    ViewData["Title"] = "My Courses";
    var user = ViewBag.User as Learnova.Models.Entities.ApplicationUser;
}

<div class="row">
    <!-- Sidebar - Profile Panel -->
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="fas fa-user-circle fa-5x text-primary"></i>
                </div>
                <h5>@user.FirstName @user.LastName</h5>
                <p class="text-muted">@user.Email</p>

                <hr />

                <div class="mb-3">
                    <h6 class="text-muted">Total Points</h6>
                    <h3 class="text-primary">@user.TotalPoints</h3>
                </div>

                <div class="mb-3">
                    <h6 class="text-muted">Badge Level</h6>
                    <span class="badge bg-warning fs-5">
                        <i class="fas fa-award"></i> @user.BadgeLevel
                    </span>
                </div>

                <div class="progress-badges">
                    <small class="text-muted">Badge Progression</small>
                    <div class="mt-2">
                        @{
                            var badges = new[] {
                                                ("Newbie", 20), ("Explorer", 40), ("Achiever", 60),
                                                ("Specialist", 80), ("Expert", 100), ("Master", 120)
                                                };
                            foreach (var (badge, points) in badges)
                            {
                                var achieved = user.TotalPoints >= points;
                                <div class="badge-item @(achieved ? "text-success" : "text-muted")">
                                    <i class="fas @(achieved ? "fa-check-circle" : "fa-circle")"></i>
                                    @badge (@points pts)
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content - Courses -->
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-book-reader"></i> My Learning</h2>
            <a asp-action="Courses" class="btn btn-primary">
                <i class="fas fa-plus"></i> Browse More Courses
            </a>
        </div>

        <!-- Search -->
        <form asp-action="MyCourses" method="get" class="mb-4">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Search my courses..." value="@ViewBag.Search" />
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                You haven't enrolled in any courses yet.
                <a asp-action="Courses" class="alert-link">Browse courses</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var enrollment in Model)
                {
                    var course = enrollment.Course;
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(course.CourseImageUrl))
                            {
                                <img src="@course.CourseImageUrl" class="card-img-top" alt="@course.Title" style="height: 180px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light" style="height: 180px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-book fa-4x text-muted"></i>
                                </div>
                            }
                            <div class="card-body">
                                <h5 class="card-title">@course.Title</h5>
                                <p class="card-text text-muted">@course.ShortDescription</p>

                                <!-- Progress Bar -->
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between">
                                        <small>Progress</small>
                                        <small>@enrollment.CompletionPercentage.ToString("F0")%</small>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar" role="progressbar"
                                             style="width: @enrollment.CompletionPercentage%"
                                             aria-valuenow="@enrollment.CompletionPercentage"
                                             aria-valuemin="0" aria-valuemax="100">
                                        </div>
                                    </div>
                                </div>

                                <div class="small text-muted">
                                    <span class="badge bg-info">@enrollment.Status</span>
                                    @if (enrollment.StartDate.HasValue)
                                    {
                                        <div class="mt-1">Started: @enrollment.StartDate.Value.ToString("MMM dd, yyyy")</div>
                                    }
                                </div>
                            </div>
                            <div class="card-footer bg-white">
                                @if (enrollment.Status == "Completed")
                                {
                                    <a asp-action="CourseDetail" asp-route-id="@course.Id" class="btn btn-success w-100">
                                        <i class="fas fa-check-circle"></i> View Certificate
                                    </a>
                                }
                                else if (enrollment.Status == "Yet to Start")
                                {
                                    <a asp-action="CourseDetail" asp-route-id="@course.Id" class="btn btn-primary w-100">
                                        <i class="fas fa-play"></i> Start Learning
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="CourseDetail" asp-route-id="@course.Id" class="btn btn-warning w-100">
                                        <i class="fas fa-redo"></i> Continue Learning
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
