@model Lesson
@{
    ViewData["Title"] = Model.Title;
    var course = ViewBag.Course as Course;
    var lessons = ViewBag.Lessons as List<Lesson> ?? new();
    var progresses = ViewBag.Progresses as List<LessonProgress> ?? new();
    var enrollment = ViewBag.Enrollment as CourseEnrollment;
    var idx = lessons.FindIndex(l => l.Id == Model.Id);
    var prev = idx > 0 ? lessons[idx-1] : null;
    var next = idx < lessons.Count-1 ? lessons[idx+1] : null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title - Player</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { margin:0; background:#111; color:#fff; overflow:hidden; }
        .player-layout { display:flex; height:100vh; }
        .sidebar { width:320px; background:#1a1a1a; border-right:1px solid #333; transition:transform .3s; overflow-y:auto; }
        .sidebar.collapsed { transform:translateX(-100%); position:absolute; z-index:10; }
        .main-area { flex:1; display:flex; flex-direction:column; background:#000; }
        .viewer { flex:1; display:flex; align-items:center; justify-content:center; padding:20px; }
        .viewer video, .viewer img { max-width:100%; max-height:80vh; border-radius:8px; }
        .controls { padding:15px; background:#1a1a1a; display:flex; justify-content:space-between; align-items:center; }
        .lesson-row { padding:12px; border-bottom:1px solid #333; cursor:pointer; display:flex; align-items:center; }
        .lesson-row:hover { background:#252525; }
        .lesson-row.active { background:#0d6efd; }
        .toggle-btn { position:fixed; left:10px; top:10px; z-index:20; background:#333; color:#fff; border:none; padding:8px 12px; border-radius:4px; }
        .attachments, .LessonAttachments {
            background: #222;
            padding: 10px;
            margin-top: 5px;
            border-radius: 4px;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <button class="toggle-btn" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>
    
    <div class="player-layout">
        <div class="sidebar" id="sidebar">
            <div class="p-3 border-bottom border-secondary">
                <h5 class="fw-bold mb-1">@course.Title</h5>
                <small class="text-muted">@enrollment.CompletionPercentage% Complete</small>
            </div>
            @foreach(var l in lessons){
                var done = progresses.Any(p => p.LessonId == l.Id && p.IsCompleted);
                var isAct = l.Id == Model.Id;
                <div class="lesson-row @(isAct?"active":"")" onclick="location.href='@Url.Action("Player", new{lessonId=l.Id})'">
                    <i class="fas fa-@(done?"check-circle text-success":"circle text-muted") me-2"></i>
                    <div class="flex-grow-1">
                        <div class="fw-bold">@l.Title</div>
                        <div class="small text-muted">@l.LessonType</div>
                        @if(l.LessonAttachments?.Any() == true){
                            <div class="attachments">
                                <i class="fas fa-paperclip me-1"></i> @l.LessonAttachments.Count attachment(s)
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="main-area">
            <div class="p-3 bg-dark border-bottom border-secondary">
                <h4 class="mb-1">@Model.Title</h4>
                <p class="text-muted small mb-0">@Model.Description</p>
            </div>
            
            <div class="viewer">
                @if(Model.LessonType == "Video" && !string.IsNullOrEmpty(Model.VideoUrl)){
                    var vidId = Model.VideoUrl.Contains("youtu") ? Model.VideoUrl.Split('/').Last().Split('?')[0] : "";
                    if(!string.IsNullOrEmpty(vidId)){
                        <iframe width="100%" height="100%" src="https://www.youtube.com/embed/@vidId" frameborder="0" allowfullscreen></iframe>
                    } else {
                        <video controls src="@Model.VideoUrl" style="max-height:80vh;"></video>
                    }
                } else if(Model.LessonType == "Document" && !string.IsNullOrEmpty(Model.DocumentUrl)){
                    <iframe src="@Model.DocumentUrl" style="width:100%; height:80vh; border:none;"></iframe>
                } else if(Model.LessonType == "Image" && !string.IsNullOrEmpty(Model.ImageUrl)){
                    <img src="@Model.ImageUrl" />
                } else {
                    <div class="text-center text-muted"><i class="fas fa-file fa-3x mb-2"></i><br>Content not available</div>
                }
            </div>

            <div class="controls">
                <button class="btn btn-secondary" onclick="window.history.back()"><i class="fas fa-arrow-left"></i> Back</button>
                <div>
                    @if(!progresses.Any(p => p.LessonId == Model.Id && p.IsCompleted)){
                        <button class="btn btn-success me-2" onclick="markComplete(@Model.Id)"><i class="fas fa-check"></i> Mark Complete</button>
                    }
                    @if(next != null){
                        <a href="@Url.Action("Player", new{lessonId=next.Id})" class="btn btn-primary">Next <i class="fas fa-arrow-right"></i></a>
                    } else {
                        <button class="btn btn-warning" onclick="completeCourse(@course.Id)"><i class="fas fa-trophy"></i> Complete Course</button>
                    }
                </div>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_PointsPopup")
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        function toggleSidebar(){ $('#sidebar').toggleClass('collapsed'); }
        function markComplete(id){
            $.post('@Url.Action("MarkLessonComplete")', {lessonId:id}).done(res=>{
                if(res.success) location.reload();
            });
        }
        function completeCourse(courseId){
            $.post('@Url.Action("CompleteCourse")', {courseId}).done(res=>{
                alert(res.message);
                if(res.success) window.location.href = '@Url.Action("MyCourses")';
            });
        }
    </script>
</body>
</html>
