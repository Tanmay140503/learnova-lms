@model Course
@using Learnova.Models.Entities
@{
    ViewData["Title"] = Model.Title;
    var userId = ViewBag.UserId as string;
    var enrollment = ViewBag.Enrollment as CourseEnrollment;
    var progresses = ViewBag.Progresses as List<LessonProgress> ?? new List<LessonProgress>();
    var reviews = ViewBag.Reviews as List<CourseReview> ?? new List<CourseReview>();
    var avgRating = ViewBag.AverageRating != null ? (double)ViewBag.AverageRating : 0;
    var tab = ViewBag.ActiveTab as string ?? "overview";
    var isEnrolled = enrollment != null;

    var totalCount = Model.Lessons?.Count ?? 0;
    var completedCount = progresses.Count(p => p.IsCompleted);
    var progressPct = totalCount > 0 ? (completedCount * 100) / totalCount : 0;
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Courses"><i class="fas fa-book me-1"></i> Courses</a>
            </li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link @(tab == "overview" ? "active" : "")" href="?tab=overview">
                <i class="fas fa-info-circle me-1"></i> Overview
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(tab == "reviews" ? "active" : "")" href="?tab=reviews">
                <i class="fas fa-star me-1"></i> Reviews (@reviews.Count)
            </a>
        </li>
    </ul>

    @if (tab == "overview")
    {
        <div class="row g-4">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- Course Header -->
                <div class="card shadow-sm border-0 mb-4">
                    @if (!string.IsNullOrEmpty(Model.CourseImageUrl))
                    {
                        <img src="@Model.CourseImageUrl" class="card-img-top" style="max-height: 300px; object-fit: cover;" alt="@Model.Title" />
                    }
                    else
                    {
                        <div class="card-img-top bg-gradient-primary d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="fas fa-book fa-5x text-white opacity-50"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h2 class="fw-bold mb-3">@Model.Title</h2>

                        @if (!string.IsNullOrEmpty(Model.ShortDescription))
                        {
                            <p class="lead text-muted">@Model.ShortDescription</p>
                        }

                        <div class="d-flex flex-wrap gap-3 text-muted mb-3">
                            <span><i class="fas fa-book-open me-1"></i> @Model.TotalLessons lessons</span>
                            <span><i class="fas fa-clock me-1"></i> @Model.TotalDurationMinutes min</span>
                            <span><i class="fas fa-eye me-1"></i> @Model.ViewsCount views</span>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Tags))
                        {
                            <div class="mb-3">
                                @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="badge bg-light text-dark me-1">@tag.Trim()</span>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Progress (if enrolled) -->
                @if (isEnrolled)
                {
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="fw-bold mb-0">Your Progress</h5>
                                <span class="badge bg-primary fs-6">@progressPct%</span>
                            </div>
                            <div class="progress mb-3" style="height: 10px;">
                                <div class="progress-bar bg-success" style="width: @progressPct%"></div>
                            </div>
                            <div class="d-flex gap-3 text-muted small">
                                <span><i class="fas fa-check-circle text-success me-1"></i> @completedCount Completed</span>
                                <span><i class="fas fa-circle text-muted me-1"></i> @(totalCount - completedCount) Remaining</span>
                            </div>
                        </div>
                    </div>
                }

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white">
                            <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2 text-primary"></i>About This Course</h5>
                        </div>
                        <div class="card-body">
                            @Html.Raw(Model.Description)
                        </div>
                    </div>
                }

                <!-- Lessons List -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-list me-2 text-primary"></i>Course Content</h5>
                        <input type="text" id="lessonSearch" class="form-control form-control-sm w-auto" placeholder="Search lessons..." />
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Lessons != null && Model.Lessons.Any())
                        {
                            <div class="list-group list-group-flush" id="lessonsList">
                                @foreach (var lesson in Model.Lessons.OrderBy(l => l.OrderIndex))
                                {
                                    var isDone = progresses.Any(p => p.LessonId == lesson.Id && p.IsCompleted);

                                    <div class="list-group-item lesson-item">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3">
                                                @if (isDone)
                                                {
                                                    <i class="fas fa-check-circle fa-lg text-success"></i>
                                                }
                                                else if (lesson.LessonType == "Video")
                                                {
                                                    <i class="fas fa-play-circle fa-lg text-primary"></i>
                                                }
                                                else if (lesson.LessonType == "Document")
                                                {
                                                    <i class="fas fa-file-alt fa-lg text-info"></i>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-image fa-lg text-warning"></i>
                                                }
                                            </div>
                                            <div class="flex-grow-1">
                                                <h6 class="mb-1 fw-bold">@lesson.Title</h6>
                                                <small class="text-muted">
                                                    @lesson.LessonType
                                                    @if (lesson.DurationMinutes > 0)
                                                    {
                                                        <span class="ms-2"><i class="fas fa-clock me-1"></i>@lesson.DurationMinutes min</span>
                                                    }
                                                </small>
                                            </div>
                                            <div>
                                                @if (isEnrolled)
                                                {
                                                    <a asp-action="Player" asp-route-lessonId="@lesson.Id" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-play me-1"></i> @(isDone ? "Review" : "Start")
                                                    </a>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-lock text-muted"></i>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="fas fa-inbox fa-2x mb-2"></i>
                                <p class="mb-0">No lessons available yet</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Quizzes -->
                @if (Model.Quizzes != null && Model.Quizzes.Any())
                {
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white">
                            <h5 class="mb-0 fw-bold"><i class="fas fa-question-circle me-2 text-primary"></i>Assessments</h5>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var quiz in Model.Quizzes)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1 fw-bold">@quiz.Title</h6>
                                        <small class="text-muted">@quiz.Description</small>
                                    </div>
                                    @if (isEnrolled)
                                    {
                                        <a asp-action="TakeQuiz" asp-route-quizId="@quiz.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-pencil-alt me-1"></i> Take Quiz
                                        </a>
                                    }
                                    else
                                    {
                                        <i class="fas fa-lock text-muted"></i>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                    <div class="card-body">
                        <!-- Price -->
                        @if (!isEnrolled)
                        {
                            @if (Model.Price > 0)
                            {
                                <div class="text-center mb-3">
                                    <h2 class="fw-bold text-primary mb-0">₹@Model.Price.Value.ToString("F2")</h2>
                                    <small class="text-muted">One-time payment</small>
                                </div>
                            }
                            else
                            {
                                <div class="text-center mb-3">
                                    <h2 class="fw-bold text-success mb-0">FREE</h2>
                                </div>
                            }

                            @if (userId != null)
                            {
                                @if (Model.AccessRule == "OnInvitation")
                                {
                                    <button class="btn btn-warning btn-lg w-100 mb-3" disabled>
                                        <i class="fas fa-lock me-2"></i> Invitation Only
                                    </button>
                                }
                                else if (Model.AccessRule == "OnPayment" && Model.Price > 0)
                                {
                                    <button class="btn btn-primary btn-lg w-100 mb-3" onclick="joinCourse(@Model.Id)">
                                        <i class="fas fa-shopping-cart me-2"></i> Buy Now
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-success btn-lg w-100 mb-3" onclick="joinCourse(@Model.Id)">
                                        <i class="fas fa-user-plus me-2"></i> Enroll Free
                                    </button>
                                }
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Url.Action("CourseDetail", new { id = Model.Id })" class="btn btn-primary btn-lg w-100 mb-3">
                                    <i class="fas fa-sign-in-alt me-2"></i> Login to Enroll
                                </a>
                            }
                        }
                        else
                        {
                            @if (Model.Lessons != null && Model.Lessons.Any())
                            {
                                var firstLesson = Model.Lessons.OrderBy(l => l.OrderIndex).FirstOrDefault();
                                <a asp-action="Player" asp-route-lessonId="@firstLesson?.Id" class="btn btn-primary btn-lg w-100 mb-3">
                                    <i class="fas fa-play me-2"></i> @(progressPct > 0 ? "Continue Learning" : "Start Course")
                                </a>
                            }
                        }

                        <hr />

                        <h6 class="fw-bold mb-3">This course includes:</h6>
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="fas fa-book-open text-primary me-2"></i>@Model.TotalLessons lessons</li>
                            <li class="mb-2"><i class="fas fa-clock text-primary me-2"></i>@Model.TotalDurationMinutes minutes</li>
                            @if (Model.Quizzes?.Any() ?? false)
                            {
                                <li class="mb-2"><i class="fas fa-question-circle text-primary me-2"></i>@Model.Quizzes.Count quiz(zes)</li>
                            }
                            <li class="mb-2"><i class="fas fa-certificate text-primary me-2"></i>Certificate</li>
                            <li class="mb-2"><i class="fas fa-infinity text-primary me-2"></i>Lifetime access</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (tab == "reviews")
    {
        <!-- Reviews Tab -->
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <h2 class="fw-bold me-3">@avgRating.ToString("F1")</h2>
                    <div>
                        <div class="text-warning fs-4">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star@(i <= Math.Round(avgRating) ? "" : "-o")"></i>
                            }
                        </div>
                        <small class="text-muted">@reviews.Count reviews</small>
                    </div>
                </div>

                @if (isEnrolled)
                {
                    <div class="border rounded p-3 mb-4">
                        <h6 class="fw-bold">Write a Review</h6>
                        <form id="reviewForm">
                            <div class="mb-3">
                                <label class="form-label">Rating</label>
                                <div class="rating-input">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        <input type="radio" name="rating" value="@i" id="star@i" required />
                                        <label for="star@i" class="text-warning fs-4"><i class="fas fa-star"></i></label>
                                    }
                                </div>
                            </div>
                            <div class="mb-3">
                                <textarea id="reviewText" class="form-control" rows="3" placeholder="Share your experience..." required></textarea>
                            </div>
                            <button type="button" class="btn btn-primary" onclick="submitReview(@Model.Id)">
                                <i class="fas fa-paper-plane me-1"></i> Submit
                            </button>
                        </form>
                    </div>
                }

                @if (reviews.Any())
                {
                    @foreach (var review in reviews.OrderByDescending(r => r.CreatedAt))
                    {
                        <div class="border-bottom pb-3 mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <div>
                                    <strong>@review.User?.FirstName @review.User?.LastName</strong>
                                    <div class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="fas fa-star@(i <= review.Rating ? "" : "-o")"></i>
                                        }
                                    </div>
                                </div>
                                <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                            </div>
                            <p class="mb-0">@review.ReviewText</p>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-comment-slash fa-2x mb-2"></i>
                        <p class="mb-0">No reviews yet. Be the first to review!</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Lesson search
        $('#lessonSearch').on('keyup', function() {
            var val = $(this).val().toLowerCase();
            $('.lesson-item').each(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(val) > -1);
            });
        });

        // Join course
        function joinCourse(courseId) {
            if (!confirm('Do you want to enroll in this course?')) return;

            $.post('@Url.Action("JoinCourse")', { courseId: courseId })
                .done(function(res) {
                    if (res.success) {
                        alert('Successfully enrolled!');
                        location.reload();
                    } else if (res.requiresPayment) {
                        alert('Payment integration pending. Price: $' + res.price);
                    } else {
                        alert(res.message);
                    }
                })
                .fail(function() {
                    alert('Error occurred. Please try again.');
                });
        }

        // Submit review
        function submitReview(courseId) {
            var rating = $('input[name="rating"]:checked').val();
            var text = $('#reviewText').val().trim();

            if (!rating) { alert('Please select a rating'); return; }
            if (!text) { alert('Please write a review'); return; }

            $.post('@Url.Action("AddReview")', { courseId: courseId, rating: rating, reviewText: text })
                .done(function(res) {
                    alert(res.message);
                    if (res.success) location.reload();
                })
                .fail(function() {
                    alert('Error occurred. Please try again.');
                });
        }
    </script>
}

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .rating-input {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

        .rating-input input {
            display: none;
        }

        .rating-input label {
            cursor: pointer;
            color: #ddd;
        }

            .rating-input input:checked ~ label,
            .rating-input label:hover,
            .rating-input label:hover ~ label {
                color: #ffc107;
            }
</style>
