@model List<Course>
@using Learnova.Models.Entities
@{
    ViewData["Title"] = "Browse Courses";
    var search = ViewBag.Search as string ?? "";
    var userId = ViewBag.UserId as string;
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <h2 class="fw-bold mb-2">
                <i class="fas fa-book text-primary me-2"></i>
                Discover Courses
            </h2>
            <p class="text-muted">Explore our extensive library of courses and start learning today</p>
        </div>
        <div class="col-lg-4">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="search" class="form-control" 
                       placeholder="Search by title or tags..." 
                       value="@search" />
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(search))
                {
                    <a href="@Url.Action("Courses")" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i>
                    </a>
                }
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(search))
    {
        <div class="alert alert-info mb-4">
            <i class="fas fa-search me-2"></i>
            Showing results for: <strong>@search</strong>
            (@Model.Count course@(Model.Count != 1 ? "s" : "") found)
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted mb-3">
                <i class="fas fa-book-open"></i>
            </div>
            <h4 class="text-muted mb-3">No courses found</h4>
            @if (!string.IsNullOrEmpty(search))
            {
                <p>Try adjusting your search terms</p>
                <a href="@Url.Action("Courses")" class="btn btn-primary">
                    <i class="fas fa-redo me-2"></i> Show All Courses
                </a>
            }
            else
            {
                <p>Check back later for new content!</p>
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var course in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 shadow-sm border-0 hover-lift">
                        <!-- Course Image -->
                        <div class="position-relative overflow-hidden" style="height: 200px;">
                            @if (!string.IsNullOrEmpty(course.CourseImageUrl))
                            {
                                <img src="@course.CourseImageUrl" class="card-img-top h-100 w-100" 
                                     style="object-fit: cover;" alt="@course.Title" />
                            }
                            else
                            {
                                <div class="bg-gradient-primary h-100 d-flex align-items-center justify-content-center">
                                    <i class="fas fa-book fa-4x text-white opacity-50"></i>
                                </div>
                            }
                            
                            <!-- Price Badge -->
                            @if (course.Price > 0)
                            {
                                <span class="badge bg-success position-absolute top-0 end-0 m-3">
                                    ₹@course.Price.Value.ToString("F2")
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-info position-absolute top-0 end-0 m-3">
                                    FREE
                                </span>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <!-- Course Title -->
                            <h5 class="card-title fw-bold mb-2">
                                <a asp-action="CourseDetail" asp-route-id="@course.Id" 
                                   class="text-decoration-none text-dark stretched-link">
                                    @course.Title
                                </a>
                            </h5>

                            <!-- Short Description -->
                            @if (!string.IsNullOrEmpty(course.ShortDescription))
                            {
                                <p class="card-text text-muted small mb-3">
                                    @(course.ShortDescription.Length > 100 
                                        ? course.ShortDescription.Substring(0, 100) + "..." 
                                        : course.ShortDescription)
                                </p>
                            }

                            <!-- Tags -->
                            @if (!string.IsNullOrEmpty(course.Tags))
                            {
                                <div class="mb-3">
                                    @foreach (var tag in course.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries).Take(3))
                                    {
                                        <span class="badge bg-light text-dark me-1 mb-1">
                                            <i class="fas fa-tag fa-xs me-1"></i>@tag.Trim()
                                        </span>
                                    }
                                </div>
                            }

                            <!-- Course Stats -->
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between text-muted small mb-2">
                                    <span>
                                        <i class="fas fa-book-open me-1"></i>
                                        @course.TotalLessons lesson@(course.TotalLessons != 1 ? "s" : "")
                                    </span>
                                    <span>
                                        <i class="fas fa-clock me-1"></i>
                                        @course.TotalDurationMinutes min
                                    </span>
                                    <span>
                                        <i class="fas fa-eye me-1"></i>
                                        @course.ViewsCount
                                    </span>
                                </div>

                                <!-- Access Rule Badge -->
                                @if (course.AccessRule == "OnInvitation")
                                {
                                    <span class="badge bg-warning text-dark w-100">
                                        <i class="fas fa-lock me-1"></i> Invitation Only
                                    </span>
                                }
                                else if (course.AccessRule == "OnPayment")
                                {
                                    <span class="badge bg-primary w-100">
                                        <i class="fas fa-credit-card me-1"></i> Paid Course
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success w-100">
                                        <i class="fas fa-unlock me-1"></i> Open Access
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // Search functionality already handled by form submit
    </script>
}

<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
    }
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
</style>
