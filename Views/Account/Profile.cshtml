@{
    ViewData["Title"] = "My Profile";
    var user = ViewBag.User as Learnova.Models.Entities.ApplicationUser;
    var enrollments = ViewBag.Enrollments as List<Learnova.Models.Entities.CourseEnrollment>;
}

<div class="container py-4">
    <div class="row">
        <!-- Profile Card -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="profile-avatar mx-auto mb-3">
                        <i class="fas fa-user"></i>
                    </div>
                    <h4 class="fw-bold mb-1">@user.FirstName @user.LastName</h4>
                    <p class="text-muted mb-3">@user.Email</p>

                    <div class="d-flex justify-content-center gap-2 mb-3">
                        @if (User.IsInRole("Admin"))
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        @if (User.IsInRole("Instructor"))
                        {
                            <span class="badge bg-primary">Instructor</span>
                        }
                        @if (User.IsInRole("Learner"))
                        {
                            <span class="badge bg-success">Learner</span>
                        }
                    </div>

                    <hr />

                    <!-- Points & Badge -->
                    <div class="row text-center">
                        <div class="col-6">
                            <h3 class="text-primary fw-bold mb-0">@user.TotalPoints</h3>
                            <small class="text-muted">Total Points</small>
                        </div>
                        <div class="col-6">
                            <div class="badge-display">
                                <span class="badge bg-warning fs-6 p-2">
                                    <i class="fas fa-award me-1"></i> @user.BadgeLevel
                                </span>
                            </div>
                            <small class="text-muted d-block mt-1">Current Badge</small>
                        </div>
                    </div>

                    <hr />

                    <!-- Badge Progression -->
                    <h6 class="text-muted mb-3">Badge Progression</h6>
                    @{
                        var badges = new[] {
                                        ("Newbie", 20, "secondary"),
                                        ("Explorer", 40, "info"),
                                        ("Achiever", 60, "success"),
                                        ("Specialist", 80, "primary"),
                                        ("Expert", 100, "warning"),
                                        ("Master", 120, "danger")
                                        };
                    }

                    @foreach (var (badge, points, color) in badges)
                    {
                        var achieved = user.TotalPoints >= points;
                        var progressWidth = achieved ? 100 : Math.Min((user.TotalPoints * 100 / points), 100);

                        <div class="mb-2">
                            <div class="d-flex justify-content-between small">
                                <span class="@(achieved ? "text-success fw-bold" : "text-muted")">
                                    <i class="fas @(achieved ? "fa-check-circle" : "fa-circle") me-1"></i> @badge
                                </span>
                                <span class="text-muted">@points pts</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-@color" style="width: @progressWidth%"></div>
                            </div>
                        </div>
                    }

                    <hr />

                    <div class="small text-muted">
                        <i class="fas fa-calendar me-1"></i> Member since @user.CreatedAt.ToString("MMM yyyy")
                    </div>
                </div>
            </div>

            <!-- Edit Profile Button -->
            <div class="d-grid gap-2 mt-3">
                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                    <i class="fas fa-edit me-2"></i> Edit Profile
                </button>
                <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                    <i class="fas fa-key me-2"></i> Change Password
                </button>
            </div>
        </div>

        <!-- Stats & Activity -->
        <div class="col-md-8">
            <!-- Quick Stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card bg-primary text-white h-100">
                        <div class="card-body text-center">
                            <h2 class="fw-bold mb-0">@(enrollments?.Count ?? 0)</h2>
                            <small>Enrolled Courses</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-success text-white h-100">
                        <div class="card-body text-center">
                            <h2 class="fw-bold mb-0">@(enrollments?.Count(e => e.Status == "Completed") ?? 0)</h2>
                            <small>Completed</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-warning text-white h-100">
                        <div class="card-body text-center">
                            <h2 class="fw-bold mb-0">@(enrollments?.Count(e => e.Status == "In Progress") ?? 0)</h2>
                            <small>In Progress</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-history me-2"></i> Recent Courses</h5>
                </div>
                <div class="card-body p-0">
                    @if (enrollments == null || !enrollments.Any())
                    {
                        <div class="text-center p-5 text-muted">
                            <i class="fas fa-book-open fa-3x mb-3 opacity-50"></i>
                            <p class="mb-0">You haven't enrolled in any courses yet.</p>
                            <a asp-controller="Learner" asp-action="Courses" class="btn btn-primary mt-3">
                                Browse Courses
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Course</th>
                                        <th>Progress</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var enrollment in enrollments.Take(5))
                                    {
                                        <tr>
                                            <td>
                                                <strong>@enrollment.Course.Title</strong>
                                            </td>
                                            <td>
                                                <div class="progress" style="width: 120px; height: 8px;">
                                                    <div class="progress-bar bg-success"
                                                         style="width: @enrollment.CompletionPercentage%"></div>
                                                </div>
                                                <small class="text-muted">@enrollment.CompletionPercentage.ToString("F0")%</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-@(enrollment.Status == "Completed" ? "success" :
                                                                                                                              enrollment.Status == "In Progress" ? "warning" : "secondary")">
                                                    @enrollment.Status
                                                </span>
                                            </td>
                                            <td>
                                                <a asp-controller="Learner" asp-action="CourseDetail"
                                                   asp-route-id="@enrollment.CourseId" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (enrollments.Count > 5)
                        {
                            <div class="card-footer bg-white text-center">
                                <a asp-controller="Learner" asp-action="MyCourses" class="text-primary text-decoration-none">
                                    View All Courses <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editProfileModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateProfile" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">First Name</label>
                        <input type="text" name="FirstName" class="form-control" value="@user.FirstName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Last Name</label>
                        <input type="text" name="LastName" class="form-control" value="@user.LastName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" value="@user.Email" disabled />
                        <small class="text-muted">Email cannot be changed</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Change Password Modal -->
<div class="modal fade" id="changePasswordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Change Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ChangePassword" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Current Password</label>
                        <input type="password" name="CurrentPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input type="password" name="NewPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm New Password</label>
                        <input type="password" name="ConfirmPassword" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Change Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 3rem;
        box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
    }
</style>
