@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-5">
                    <h1 class="fw-bold mb-4">
                        <i class="fas fa-shield-alt text-primary me-2"></i> Privacy Policy
                    </h1>
                    <p class="text-muted">Last updated: January 2024</p>
                    
                    <hr class="my-4">

                    <section class="mb-4">
                        <h4 class="fw-bold">1. Introduction</h4>
                        <p>
                            Welcome to Learnova ("we," "our," or "us"). We are committed to protecting your 
                            personal information and your right to privacy. This Privacy Policy explains how 
                            we collect, use, and share information about you when you use our eLearning platform.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-bold">2. Information We Collect</h4>
                        <p>We collect information you provide directly to us, such as:</p>
                        <ul>
                            <li>Name and email address when you register</li>
                            <li>Profile information you choose to provide</li>
                            <li>Course progress and quiz responses</li>
                            <li>Reviews and ratings you submit</li>
                            <li>Communications with us</li>
                        </ul>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-bold">3. How We Use Your Information</h4>
                        <p>We use the information we collect to:</p>
                        <ul>
                            <li>Provide, maintain, and improve our services</li>
                            <li>Track your learning progress and award points/badges</li>
                            <li>Send you technical notices and support messages</li>
                            <li>Respond to your comments and questions</li>
                            <li>Generate analytics and reports for instructors</li>
                        </ul>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-bold">4. Data Security</h4>
                        <p>
                            We take reasonable measures to help protect your personal information from loss, 
                            theft, misuse, and unauthorized access. We use industry-standard encryption and 
                            secure authentication methods.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-bold">5. Your Rights</h4>
                        <p>You have the right to:</p>
                        <ul>
                            <li>Access your personal data</li>
                            <li>Correct inaccurate data</li>
                            <li>Request deletion of your data</li>
                            <li>Export your learning progress</li>
                        </ul>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-bold">6. Contact Us</h4>
                        <p>
                            If you have any questions about this Privacy Policy, please contact us at:
                        </p>
                        <p>
                            <i class="fas fa-envelope me-2"></i> privacy@learnova.com<br>
                            <i class="fas fa-phone me-2"></i> +1 (555) 123-4567
                        </p>
                    </section>

                    <div class="mt-5">
                        <a asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-arrow-left me-2"></i> Back to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
