@{
    ViewData["Title"] = "Welcome to Learnova";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-6 fade-in">
                <span class="badge bg-primary mb-3 px-3 py-2">🎓 #1 eLearning Platform</span>
                <h1 class="display-3 fw-bold mb-4">
                    Learn Without <span class="text-gradient">Limits</span>
                </h1>
                <p class="lead text-muted mb-4">
                    Discover thousands of courses from expert instructors.
                    Build skills with courses, certificates, and degrees online
                    from world-class universities and companies.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Learner" asp-action="Courses" class="btn btn-primary btn-lg px-4">
                        <i class="fas fa-search me-2"></i> Explore Courses
                    </a>
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg px-4">
                            <i class="fas fa-user-plus me-2"></i> Get Started Free
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Learner" asp-action="MyCourses" class="btn btn-outline-primary btn-lg px-4">
                            <i class="fas fa-book-reader me-2"></i> My Learning
                        </a>
                    }
                </div>

                <!-- Stats -->
                <div class="row mt-5 pt-4 g-4 text-center">

                    <!-- Active Learners -->
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-4">
                                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex
                            align-items-center justify-content-center mb-3"
                                     style="width:70px; height:70px;">
                                    <i class="fas fa-users fa-2x text-primary"></i>
                                </div>
                                <h2 class="fw-bold text-primary mb-1" id="learnerCount">
                                    @(ViewBag.TotalLearners ?? 0)
                                </h2>
                                <p class="text-muted mb-0">Active Learners</p>
                            </div>
                        </div>
                    </div>

                    <!-- Total Courses -->
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-4">
                                <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex
                            align-items-center justify-content-center mb-3"
                                     style="width:70px; height:70px;">
                                    <i class="fas fa-book-open fa-2x text-success"></i>
                                </div>
                                <h2 class="fw-bold text-success mb-1" id="courseCount">
                                    @(ViewBag.TotalCourses ?? 0)
                                </h2>
                                <p class="text-muted mb-0">Expert Courses</p>
                            </div>
                        </div>
                    </div>

                    <!-- Total Instructors -->
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body py-4">
                                <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex
                            align-items-center justify-content-center mb-3"
                                     style="width:70px; height:70px;">
                                    <i class="fas fa-chalkboard-teacher fa-2x text-warning"></i>
                                </div>
                                <h2 class="fw-bold text-warning mb-1" id="instructorCount">
                                    @(ViewBag.TotalInstructors ?? 0)
                                </h2>
                                <p class="text-muted mb-0">Total Instructors</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            <div class="col-lg-6 text-center slide-in-right">
                <div class="hero-image-container">
                    <img src="https://illustrations.popsy.co/amber/student-going-to-school.svg"
                         alt="Learning Illustration" class="img-fluid hero-image" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="features-section py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Why Choose <span class="text-gradient">Learnova</span>?</h2>
            <p class="text-muted">Everything you need to achieve your learning goals</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="feature-icon bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-4">
                            <i class="fas fa-video fa-2x"></i>
                        </div>
                        <h5 class="fw-bold">Video Lessons</h5>
                        <p class="text-muted mb-0">
                            Learn through high-quality video content from industry experts.
                            Watch anytime, anywhere on any device.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="feature-icon bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-4">
                            <i class="fas fa-trophy fa-2x"></i>
                        </div>
                        <h5 class="fw-bold">Earn Badges</h5>
                        <p class="text-muted mb-0">
                            Complete quizzes, earn points, and unlock badges.
                            Show off your achievements to the world.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="feature-icon bg-warning bg-opacity-10 text-warning rounded-circle mx-auto mb-4">
                            <i class="fas fa-certificate fa-2x"></i>
                        </div>
                        <h5 class="fw-bold">Certificates</h5>
                        <p class="text-muted mb-0">
                            Get certified upon course completion.
                            Add credentials to your resume and LinkedIn.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section class="how-it-works-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">How It <span class="text-gradient">Works</span></h2>
            <p class="text-muted">Start learning in just 3 simple steps</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4 text-center">
                <div class="step-number bg-primary text-white rounded-circle mx-auto mb-3">1</div>
                <h5 class="fw-bold">Create Account</h5>
                <p class="text-muted">Sign up for free and set up your learning profile in seconds.</p>
            </div>
            <div class="col-md-4 text-center">
                <div class="step-number bg-primary text-white rounded-circle mx-auto mb-3">2</div>
                <h5 class="fw-bold">Choose Courses</h5>
                <p class="text-muted">Browse our catalog and enroll in courses that match your goals.</p>
            </div>
            <div class="col-md-4 text-center">
                <div class="step-number bg-primary text-white rounded-circle mx-auto mb-3">3</div>
                <h5 class="fw-bold">Start Learning</h5>
                <p class="text-muted">Learn at your pace, complete quizzes, and earn your certificate.</p>
            </div>
        </div>
    </div>
</section>



<!-- Badges Section -->
<section class="badges-section py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Earn <span class="text-gradient">Badges & Rewards</span></h2>
            <p class="text-muted">Complete courses, take quizzes, and unlock achievements</p>
        </div>

        <div class="row justify-content-center g-4">
            <div class="col-6 col-md-2 text-center">
                <div class="badge-display">
                    <div class="badge-icon-large bg-secondary text-white">
                        <i class="fas fa-seedling"></i>
                    </div>
                    <h6 class="mt-2 mb-0">Newbie</h6>
                    <small class="text-muted">20 Points</small>
                </div>
            </div>
            <div class="col-6 col-md-2 text-center">
                <div class="badge-display">
                    <div class="badge-icon-large bg-info text-white">
                        <i class="fas fa-compass"></i>
                    </div>
                    <h6 class="mt-2 mb-0">Explorer</h6>
                    <small class="text-muted">40 Points</small>
                </div>
            </div>
            <div class="col-6 col-md-2 text-center">
                <div class="badge-display">
                    <div class="badge-icon-large bg-success text-white">
                        <i class="fas fa-medal"></i>
                    </div>
                    <h6 class="mt-2 mb-0">Achiever</h6>
                    <small class="text-muted">60 Points</small>
                </div>
            </div>
            <div class="col-6 col-md-2 text-center">
                <div class="badge-display">
                    <div class="badge-icon-large bg-primary text-white">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <h6 class="mt-2 mb-0">Specialist</h6>
                    <small class="text-muted">80 Points</small>
                </div>
            </div>
            <div class="col-6 col-md-2 text-center">
                <div class="badge-display">
                    <div class="badge-icon-large bg-warning text-white">
                        <i class="fas fa-crown"></i>
                    </div>
                    <h6 class="mt-2 mb-0">Expert</h6>
                    <small class="text-muted">100 Points</small>
                </div>
            </div>
            <div class="col-6 col-md-2 text-center">
                <div class="badge-display">
                    <div class="badge-icon-large bg-danger text-white">
                        <i class="fas fa-gem"></i>
                    </div>
                    <h6 class="mt-2 mb-0">Master</h6>
                    <small class="text-muted">120 Points</small>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section py-5">
    <div class="container">
        <div class="card bg-primary text-white border-0 overflow-hidden">
            <div class="card-body p-5 text-center position-relative">
                <div class="cta-bg-pattern"></div>
                <h2 class="fw-bold mb-3">Ready to Start Learning?</h2>
                <p class="lead mb-4 opacity-75">
                    Join thousands of learners already learning on Learnova
                </p>
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5">
                        <i class="fas fa-rocket me-2"></i> Get Started for Free
                    </a>
                }
                else
                {
                    <a asp-controller="Learner" asp-action="Courses" class="btn btn-light btn-lg px-5">
                        <i class="fas fa-book-open me-2"></i> Browse Courses
                    </a>
                }
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="footer bg-dark text-white py-5 mt-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="fw-bold mb-3">
                    <i class="fas fa-graduation-cap me-2"></i> Learnova
                </h5>
                <p class="text-muted">
                    Empowering learners worldwide with quality education.
                    Learn from experts and transform your career.
                </p>
                <div class="social-links">
                    <a href="#" class="text-white me-3"><i class="fab fa-facebook fa-lg"></i></a>
                    <a href="#" class="text-white me-3"><i class="fab fa-twitter fa-lg"></i></a>
                    <a href="#" class="text-white me-3"><i class="fab fa-linkedin fa-lg"></i></a>
                    <a href="#" class="text-white me-3"><i class="fab fa-instagram fa-lg"></i></a>
                </div>
            </div>
            <div class="col-md-2">
                <h6 class="fw-bold mb-3">Quick Links</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">About Us</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Courses</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Instructors</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Contact</a></li>
                </ul>
            </div>
            <div class="col-md-2">
                <h6 class="fw-bold mb-3">Support</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Help Center</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">FAQs</a></li>
                    <li class="mb-2"><a asp-action="Privacy" class="text-muted text-decoration-none">Privacy Policy</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Terms of Service</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="fw-bold mb-3">Newsletter</h6>
                <p class="text-muted small">Subscribe to get updates on new courses and offers.</p>
                <div class="input-group">
                    <input type="email" class="form-control" placeholder="Enter your email">
                    <button class="btn btn-primary" type="button">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
        <hr class="my-4 opacity-25">
        <div class="row">
            <div class="col-md-6">
                <p class="text-muted small mb-0">
                    &copy; 2026 Learnova. All rights reserved.
                </p>
            </div>
            <div class="col-md-6 text-md-end">
                <p class="text-muted small mb-0">
                    Made with <i class="fas fa-heart text-danger"></i> for Oddo Hackathon
                </p>
            </div>
        </div>
    </div>
</footer>

<style>
    .min-vh-75 {
        min-height: 75vh;
    }

    .hero-section {
        background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
        padding: 3rem 0;
    }

    .hero-image {
        max-height: 500px;
        filter: drop-shadow(0 20px 40px rgba(0,0,0,0.15));
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-15px);
        }
    }

    .feature-icon {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .feature-card:hover {
        transform: translateY(-10px);
    }

    .step-number {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: bold;
    }

    .category-card {
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .category-card:hover {
            transform: translateY(-5px);
            border-color: var(--bs-primary) !important;
        }

    .testimonial-avatar {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .badge-icon-large {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        font-size: 1.5rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        transition: transform 0.3s ease;
    }

    .badge-display:hover .badge-icon-large {
        transform: scale(1.1) rotate(10deg);
    }

    .cta-bg-pattern {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.5;
    }

    .text-purple {
        color: #8b5cf6;
    }

    .social-links a {
        opacity: 0.7;
        transition: opacity 0.3s ease;
    }

        .social-links a:hover {
            opacity: 1;
        }
</style>
